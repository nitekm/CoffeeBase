<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".AddGroup">

    <ImageView
            android:layout_width="174dp"
            android:layout_height="145dp"
            android:src="@mipmap/coffeebean"
            android:id="@+id/imgAddCoffee"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="25dp"/>

    <EditText
            android:layout_width="250dp"
            android:layout_height="40dp"
            android:id="@+id/txtPicUrl"
            android:textSize="18sp"
            android:hint="picture url" android:gravity="center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/loadImgBtn"
            app:layout_constraintTop_toBottomOf="@+id/imgAddCoffee"
            app:layout_constraintHorizontal_bias="0.496"
            app:layout_constraintVertical_bias="0.4"/>

    <Button
            android:text="load image"
            android:layout_width="200dp"
            android:layout_height="41dp" android:id="@+id/loadImgBtn"
            app:layout_constraintEnd_toEndOf="@+id/imgAddCoffee"
            app:layout_constraintStart_toStartOf="@+id/imgAddCoffee"
            app:layout_constraintTop_toBottomOf="@+id/imgAddCoffee"
            android:layout_marginTop="48dp"
            app:layout_constraintHorizontal_bias="0.0"/>

    <TextView
            android:text="Group Name"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:id="@+id/groupAddNameTxt"
            app:layout_constraintTop_toTopOf="@+id/guideline4"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/guideline5"
            android:layout_marginTop="40dp"
            app:layout_constraintHorizontal_bias="0.502"
            android:textSize="18sp" android:gravity="center"/>

    <EditText
            android:layout_width="250dp"
            android:layout_height="40dp"
            android:id="@+id/txtAddGroupName"
            android:textSize="18sp"
            android:hint="group name"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="@+id/groupAddNameTxt"
            app:layout_constraintBottom_toBottomOf="@+id/groupAddNameTxt"
            app:layout_constraintVertical_bias="0.0"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/guideline5"/>

    <TextView
            android:text="Group Type"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:id="@+id/groupTypeTxt"
            app:layout_constraintTop_toBottomOf="@+id/groupAddNameTxt"
            android:layout_marginTop="15dp"
            app:layout_constraintStart_toStartOf="parent"
            android:textSize="18sp"
            app:layout_constraintEnd_toStartOf="@+id/guideline5"
            android:gravity="center"/>

    <Spinner
            android:layout_width="250dp"
            android:layout_height="40dp" android:id="@+id/spinner"
            app:layout_constraintTop_toTopOf="@+id/groupTypeTxt"
            app:layout_constraintBottom_toBottomOf="@+id/groupTypeTxt"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/guideline5"/>

    <Button
            android:text="Create group"
            android:layout_width="210dp"
            android:layout_height="70dp"
            android:id="@+id/createGroupBtn"
            android:textSize="18sp"
            app:layout_constraintTop_toTopOf="@+id/guideline6"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginTop="25dp"
            app:layout_constraintVertical_bias="0.287"
            app:layout_constraintHorizontal_bias="0.49"/>

    <androidx.constraintlayout.widget.Guideline
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/guideline4"
            android:orientation="horizontal"
            app:layout_constraintGuide_begin="259dp"/>

    <androidx.constraintlayout.widget.Guideline
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/guideline5"
            android:orientation="vertical"
            app:layout_constraintGuide_begin="119dp"/>

    <androidx.constraintlayout.widget.Guideline
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/guideline6"
            app:layout_constraintGuide_begin="490dp"
            android:orientation="horizontal"/>

</androidx.constraintlayout.widget.ConstraintLayout>