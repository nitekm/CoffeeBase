<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".CoffeeActivity" android:id="@+id/coffeeActivity">

    <ImageView
            android:layout_width="200dp"
            android:layout_height="200dp" tools:srcCompat="@tools:sample/avatars" android:id="@+id/imgCoffee"
            app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" android:layout_marginTop="50dp"/>
    <TextView
            android:text="Name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:id="@+id/coffeeNameTxt"
            app:layout_constraintTop_toTopOf="@+id/guideline4" app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/guideline5" android:layout_marginTop="20dp"
            app:layout_constraintHorizontal_bias="0.502" android:textSize="18sp"/>
    <androidx.constraintlayout.widget.Guideline android:layout_width="wrap_content" android:layout_height="wrap_content"
                                                android:id="@+id/guideline4" app:layout_constraintGuide_begin="333dp"
                                                android:orientation="horizontal"/>
    <androidx.constraintlayout.widget.Guideline android:layout_width="wrap_content" android:layout_height="wrap_content"
                                                android:id="@+id/guideline5" app:layout_constraintGuide_begin="205dp"
                                                android:orientation="vertical"/>
    <TextView
            android:text="TextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:id="@+id/txtCoffeeName"
            android:textSize="18sp"
            app:layout_constraintTop_toTopOf="@+id/coffeeNameTxt"
            app:layout_constraintBottom_toBottomOf="@+id/coffeeNameTxt" app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginEnd="72dp" app:layout_constraintVertical_bias="0.0"/>
    <TextView
            android:text="Origin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:id="@+id/originTxt"
            app:layout_constraintTop_toBottomOf="@+id/coffeeNameTxt"
            android:layout_marginTop="30dp" app:layout_constraintStart_toStartOf="parent"
            android:textSize="18sp"
            app:layout_constraintEnd_toStartOf="@+id/guideline5"/>
    <TextView
            android:text="TextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:id="@+id/txtOrigin"
            android:textSize="18sp"
            app:layout_constraintStart_toEndOf="@+id/originTxt"
            android:layout_marginStart="136dp" app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.065" app:layout_constraintTop_toTopOf="@+id/originTxt"
            app:layout_constraintBottom_toBottomOf="@+id/originTxt"/>
    <Button
            android:text="Add to Favourites"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:id="@+id/addToFavouritesBtn"
            app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/guideline4" app:layout_constraintBottom_toBottomOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>